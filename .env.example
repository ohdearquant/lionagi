# model providers
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# PERPLEXITY_API_KEY=
# GROQ_API_KEY=
# OPENROUTER_API_KEY=
# EXA_API_KEY=

# runtime settings
# Seconds run() waits for a CLI worker's first stream chunk before retrying
# once and then failing with WorkerLivenessError. Only applied by default to
# CLI endpoints that stream output early (claude_code, codex, pi); buffered
# endpoints (e.g. gemini_code) are unaffected unless liveness_timeout is
# passed explicitly. 0 disables the watchdog. Default: 120.
# LIONAGI_WORKER_LIVENESS_TIMEOUT=120
